generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Category {
  id     Int     @id @default(autoincrement())
  slug   String  @unique
  name   String
  nameFa String?
  icon   String?
  guides Guide[]
}

model Guide {
  id         Int        @id @default(autoincrement())
  slug       String     @unique
  categories Category[]
  title      String
  content    String
  tags       String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}
